{
  "dashboard": {
    "id": null,
    "uid": "bsic-observability",
    "title": "BSIC Observability Overview",
    "tags": ["bsic", "observability", "logs", "traces", "metrics"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Loki",
          "enable": true,
          "expr": "{job=\"bsic-backend\"} |= \"Application started\"",
          "iconColor": "green",
          "tagKeys": "job"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "up{job=\"spring-boot-backend\"}",
            "legendFormat": "Backend"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}},
              {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}}
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count[5m]))",
            "legendFormat": "req/s"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "P95 Latency",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Log Volume",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"bsic-backend\"}[1h]))",
            "legendFormat": "Logs/hour"
          }
        ]
      },
      {
        "id": 6,
        "title": "Active Traces",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(traces_spanmetrics_calls_total[5m]))",
            "legendFormat": "traces/s"
          }
        ]
      },
      {
        "id": 10,
        "title": "Request Latency Distribution",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 11,
        "title": "Request Rate by Endpoint",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "topk(10, sum(rate(http_server_requests_seconds_count[5m])) by (uri))",
            "legendFormat": "{{uri}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 20,
        "title": "Application Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{job=\"bsic-backend\"} | json | line_format \"{{.level}} [{{.logger}}] {{.message}}\"",
            "legendFormat": ""
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending",
          "dedupStrategy": "none"
        }
      },
      {
        "id": 30,
        "title": "Error Logs",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{job=\"bsic-backend\"} |~ \"(?i)error|exception|failed\"",
            "legendFormat": ""
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 31,
        "title": "Log Level Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 22},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "sum by (level) (count_over_time({job=\"bsic-backend\"}[1h]))",
            "legendFormat": "{{level}}"
          }
        ]
      },
      {
        "id": 32,
        "title": "Logs Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 22},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"bsic-backend\", level=\"ERROR\"}[5m]))",
            "legendFormat": "Errors"
          },
          {
            "expr": "sum(count_over_time({job=\"bsic-backend\", level=\"WARN\"}[5m]))",
            "legendFormat": "Warnings"
          },
          {
            "expr": "sum(count_over_time({job=\"bsic-backend\", level=\"INFO\"}[5m]))",
            "legendFormat": "Info"
          }
        ]
      },
      {
        "id": 40,
        "title": "Recent Traces",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 30},
        "datasource": "Tempo",
        "targets": [
          {
            "queryType": "search",
            "serviceName": "bsic-data-quality-backend",
            "limit": 20
          }
        ],
        "options": {
          "showHeader": true,
          "cellHeight": "sm"
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "traceID"},
              "properties": [
                {
                  "id": "links",
                  "value": [
                    {
                      "title": "View Trace",
                      "url": "/explore?left=%5B%22now-1h%22,%22now%22,%22Tempo%22,%7B%22query%22:%22${__value.raw}%22%7D%5D"
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      {
        "id": 50,
        "title": "JVM Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
        "collapsed": true,
        "panels": [
          {
            "id": 51,
            "title": "JVM Memory",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 39},
            "datasource": "Prometheus",
            "targets": [
              {
                "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
                "legendFormat": "Heap Used (MB)"
              },
              {
                "expr": "jvm_memory_max_bytes{area=\"heap\"} / 1024 / 1024",
                "legendFormat": "Heap Max (MB)"
              }
            ]
          },
          {
            "id": 52,
            "title": "GC Activity",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 39},
            "datasource": "Prometheus",
            "targets": [
              {
                "expr": "rate(jvm_gc_pause_seconds_sum[5m])",
                "legendFormat": "{{gc}} pause time"
              }
            ]
          }
        ]
      },
      {
        "id": 60,
        "title": "Database Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 47},
        "collapsed": true,
        "panels": [
          {
            "id": 61,
            "title": "Connection Pool",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
            "datasource": "Prometheus",
            "targets": [
              {
                "expr": "hikaricp_connections_active",
                "legendFormat": "{{pool}} Active"
              },
              {
                "expr": "hikaricp_connections_idle",
                "legendFormat": "{{pool}} Idle"
              }
            ]
          },
          {
            "id": 62,
            "title": "Connection Wait Time",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
            "datasource": "Prometheus",
            "targets": [
              {
                "expr": "hikaricp_connections_acquire_seconds_sum / hikaricp_connections_acquire_seconds_count",
                "legendFormat": "{{pool}} avg wait"
              }
            ]
          }
        ]
      }
    ]
  }
}
