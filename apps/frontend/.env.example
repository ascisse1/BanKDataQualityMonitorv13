# ===========================================
# MODE DE FONCTIONNEMENT
# ===========================================
# Type de base de données : "postgresql"
DB_TYPE=postgresql

# ===========================================
# CONFIGURATION POSTGRESQL (Local Database)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=bdqm
DB_PASSWORD=bdqm
DB_NAME=bdqm

# ===========================================
# CONFIGURATION KEYCLOAK (Authentication - BFF Pattern)
# ===========================================
# Uses Backend-For-Frontend (BFF) pattern for maximum security:
# - OAuth2 tokens stored server-side in HttpOnly session
# - Frontend uses session cookies only (XSS-safe)
# - CSRF protection enabled

# Keycloak server URL (without /auth suffix for Keycloak 17+)
KEYCLOAK_AUTH_SERVER_URL=http://localhost:9083
KEYCLOAK_REALM=bdqm

# Backend OAuth2 Client (confidential client - handles login flow)
KEYCLOAK_CLIENT_ID=bdqm-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_ISSUER_URI=http://localhost:9083/realms/bdqm

# Admin client for user management (requires service account with realm-management roles)
KEYCLOAK_ADMIN_CLIENT_ID=bdqm-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# ===========================================
# CONFIGURATION JWT (Legacy - deprecated)
# ===========================================
# Note: JWT is now handled by Keycloak, these are kept for Node.js backend
JWT_SECRET=your_jwt_secret_key_here_please_change_in_production
JWT_EXPIRES_IN=24h

# ===========================================
# CONFIGURATION INFORMIX CBS (Core Banking System)
# ===========================================
# Connexion JDBC au système bancaire Informix
INFORMIX_HOST=10.3.0.66
INFORMIX_PORT=1526
INFORMIX_DATABASE=bdmsa
INFORMIX_SERVER=ol_bdmsa
INFORMIX_USER=bank
INFORMIX_PASSWORD=change_this_in_production

# Mode dégradé (continuer sans Informix)
ALLOW_DEGRADED_MODE=false

# ===========================================
# SPRING BOOT BACKEND (Port 8080)
# ===========================================
SERVER_PORT=8080
VITE_SPRING_BOOT_URL=http://localhost:8080

# ===========================================
# SERVEUR NODE.JS EXPRESS (Port 3001)
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# CONFIGURATION APPLICATION
# ===========================================
VITE_APP_NAME=Data Quality Monitor
# Bank-specific branding (white-label)
VITE_BANK_NAME=Your Bank Name
VITE_APP_TITLE=Data Quality Monitor
VITE_LOGO_URL=/logo.svg
VITE_APP_VERSION=1.0.0

# Backend à utiliser :
# - Backend Node.js Express : http://localhost:3001
# - Backend Java Spring Boot : http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_URL=http://localhost:3001

# ===========================================
# SÉCURITÉ & CORS
# ===========================================
# Include Keycloak URL for CORS (required for OAuth2 redirects)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:9083
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# INTÉGRATION RPA UIPATH
# ===========================================
# Optionnel - pour intégration avec UiPath Orchestrator
# RPA_ORCHESTRATOR_URL=https://your-orchestrator.uipath.com
# RPA_ORCHESTRATOR_TENANT=your_tenant
# RPA_ORCHESTRATOR_API_KEY=your_api_key

# ===========================================
# MONITORING & LOGS
# ===========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/application.log
ENABLE_PERFORMANCE_MONITORING=true
