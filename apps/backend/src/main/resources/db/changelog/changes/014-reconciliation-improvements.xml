<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Reconciliation audit trail -->
    <changeSet id="014-1-create-reconciliation-attempts" author="bdqm">
        <createTable tableName="reconciliation_attempts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="task_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attempt_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="matched_fields" type="INT" defaultValueNumeric="0"/>
            <column name="total_fields" type="INT" defaultValueNumeric="0"/>
            <column name="error_message" type="TEXT"/>
            <column name="duration_ms" type="BIGINT"/>
            <column name="attempted_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="reconciliation_attempts" indexName="idx_recon_attempts_task_id">
            <column name="task_id"/>
        </createIndex>
    </changeSet>

    <!-- Add abandoned_at and abandoned_reason to reconciliation_tasks -->
    <changeSet id="014-2-add-abandoned-columns" author="bdqm">
        <addColumn tableName="reconciliation_tasks">
            <column name="abandoned_at" type="DATETIME"/>
            <column name="abandoned_reason" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
