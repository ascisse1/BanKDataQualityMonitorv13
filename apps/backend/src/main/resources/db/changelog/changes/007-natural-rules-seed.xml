         ===================================================== -->

    <changeSet id="010-01-particuliers-nom" author="adakalgroup">
        <comment>Nom obligatoire - Particuliers</comment>
        <insert tableName="validation_rules">
            <column name="rule_name" value="Nom obligatoire"/>
            <column name="description" value="Le nom est obligatoire pour les clients particuliers"/>
            <column name="field_name" value="nom"/>
            <column name="field_label" value="Nom"/>
            <column name="client_type" value="1"/>
            <column name="rule_type" value="required"/>
            <column name="rule_definition" value='[{"type": "required", "message": "Le nom est obligatoire"}, {"type": "notPlaceholder", "message": "Le nom ne peut pas etre compose uniquement de X"}]'/>
            <column name="error_message" value="Le nom est obligatoire et ne peut pas etre compose uniquement de X"/>
            <column name="severity" value="CRITICAL"/>
            <column name="active" valueBoolean="true"/>
            <column name="priority" valueNumeric="1"/>
            <column name="created_by" value="system"/>
            <column name="created_at" valueComputed="NOW()"/>
        </insert>
    </changeSet>

