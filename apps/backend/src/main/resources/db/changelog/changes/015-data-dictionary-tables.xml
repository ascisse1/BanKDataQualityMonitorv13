<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- CBS Data Dictionary: Table Registry -->
    <changeSet id="015-1-create-cbs-tables" author="bdqm">
        <createTable tableName="cbs_tables">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="table_name" type="VARCHAR(30)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_cbs_table_name"/>
            </column>
            <column name="display_name" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="schema_name" type="VARCHAR(30)"/>
            <column name="cbs_version" type="VARCHAR(30)"/>
            <column name="primary_key_columns" type="VARCHAR(100)"/>
            <column name="sync_enabled" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="sync_order" type="INT"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- CBS Data Dictionary: Field/Column Registry -->
    <changeSet id="015-2-create-cbs-fields" author="bdqm">
        <createTable tableName="cbs_fields">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cbs_table_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="column_name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="display_label" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="query_alias" type="VARCHAR(50)"/>
            <column name="data_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="max_length" type="INT"/>
            <column name="precision_value" type="INT"/>
            <column name="scale_value" type="INT"/>
            <column name="is_primary_key" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_required" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_updatable" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="nomenclature_ctab" type="VARCHAR(3)"/>
            <column name="nomenclature_description" type="VARCHAR(100)"/>
            <column name="enum_values" type="JSON"/>
            <column name="applicable_client_types" type="VARCHAR(50)"/>
            <column name="display_order" type="INT"/>
            <column name="field_group" type="VARCHAR(50)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="cbs_fields" baseColumnNames="cbs_table_id"
            referencedTableName="cbs_tables" referencedColumnNames="id"
            constraintName="fk_cbs_field_table"/>

        <addUniqueConstraint tableName="cbs_fields"
            columnNames="cbs_table_id,column_name"
            constraintName="uk_cbs_field_table_column"/>

        <createIndex tableName="cbs_fields" indexName="idx_cbs_field_table">
            <column name="cbs_table_id"/>
        </createIndex>
        <createIndex tableName="cbs_fields" indexName="idx_cbs_field_nomenclature">
            <column name="nomenclature_ctab"/>
        </createIndex>
    </changeSet>

    <!-- Nomenclature Type Registry -->
    <changeSet id="015-3-create-nomenclature-types" author="bdqm">
        <createTable tableName="nomenclature_types">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ctab" type="VARCHAR(3)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_nomenclature_type_ctab"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="sync_enabled" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="entry_count" type="INT"/>
            <column name="last_synced_at" type="DATETIME"/>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Nomenclature Entries (synced from CBS bknom) -->
    <changeSet id="015-4-create-nomenclature-entries" author="bdqm">
        <createTable tableName="nomenclature_entries">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nomenclature_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="ctab" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="cacc" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="age" type="VARCHAR(5)"/>
            <column name="lib1" type="VARCHAR(30)"/>
            <column name="lib2" type="VARCHAR(30)"/>
            <column name="lib3" type="VARCHAR(30)"/>
            <column name="lib4" type="VARCHAR(30)"/>
            <column name="lib5" type="VARCHAR(30)"/>
            <column name="mnt1" type="DECIMAL(15,0)"/>
            <column name="mnt2" type="DECIMAL(15,0)"/>
            <column name="mnt3" type="DECIMAL(15,0)"/>
            <column name="mnt4" type="DECIMAL(15,0)"/>
            <column name="mnt5" type="DECIMAL(15,0)"/>
            <column name="mnt6" type="DECIMAL(15,0)"/>
            <column name="mnt7" type="DECIMAL(15,0)"/>
            <column name="mnt8" type="DECIMAL(15,0)"/>
            <column name="tau1" type="DECIMAL(15,7)"/>
            <column name="tau2" type="DECIMAL(15,7)"/>
            <column name="tau3" type="DECIMAL(15,7)"/>
            <column name="tau4" type="DECIMAL(15,7)"/>
            <column name="tau5" type="DECIMAL(15,7)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="last_synced_at" type="DATETIME"/>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="nomenclature_entries" baseColumnNames="nomenclature_type_id"
            referencedTableName="nomenclature_types" referencedColumnNames="id"
            constraintName="fk_nom_entry_type"/>

        <addUniqueConstraint tableName="nomenclature_entries"
            columnNames="ctab,cacc,age"
            constraintName="uk_nom_entry_ctab_cacc_age"/>

        <createIndex tableName="nomenclature_entries" indexName="idx_nom_entry_type">
            <column name="nomenclature_type_id"/>
        </createIndex>
        <createIndex tableName="nomenclature_entries" indexName="idx_nom_entry_ctab_cacc">
            <column name="ctab"/>
            <column name="cacc"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
