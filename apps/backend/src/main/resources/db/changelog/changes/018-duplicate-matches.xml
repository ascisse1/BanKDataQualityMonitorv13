<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="018-1-create-duplicate-matches" author="bdqm">
        <createTable tableName="duplicate_matches">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id_1" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id_2" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="client_name_1" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="client_name_2" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="similarity_score" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="matching_fields" type="TEXT"/>
            <column name="client_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="structure_code" type="VARCHAR(10)"/>
            <column name="reviewed_by" type="VARCHAR(100)"/>
            <column name="reviewed_at" type="DATETIME"/>
            <column name="review_comments" type="TEXT"/>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="duplicate_matches"
            columnNames="client_id_1,client_id_2"
            constraintName="uk_duplicate_matches_pair"/>

        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_client_type">
            <column name="client_type"/>
        </createIndex>
        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_score">
            <column name="similarity_score"/>
        </createIndex>
        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_created">
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_client1">
            <column name="client_id_1"/>
        </createIndex>
        <createIndex tableName="duplicate_matches" indexName="idx_dup_match_client2">
            <column name="client_id_2"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
