<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-1" author="bdqm">
        <comment>Add keycloak_id column to users table for OIDC user sync</comment>
        <addColumn tableName="users">
            <column name="keycloak_id" type="VARCHAR(255)">
                <constraints nullable="true" unique="true" uniqueConstraintName="uk_users_keycloak_id"/>
            </column>
        </addColumn>
        <createIndex tableName="users" indexName="idx_users_keycloak_id">
            <column name="keycloak_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="009-2" author="bdqm">
        <comment>Make password_hash nullable for OIDC-only users</comment>
        <dropNotNullConstraint tableName="users" columnName="password_hash" columnDataType="VARCHAR(255)"/>
    </changeSet>

</databaseChangeLog>
