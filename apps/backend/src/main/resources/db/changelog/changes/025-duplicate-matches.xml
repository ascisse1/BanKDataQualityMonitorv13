<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="025-01-create-duplicate-matches" author="adakalgroup">
        <createTable tableName="duplicate_matches" schemaName="public">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id_1" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id_2" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="client_name_1" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="client_name_2" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="similarity_score" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="matching_fields" type="TEXT"/>
            <column name="client_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="structure_code" type="VARCHAR(10)"/>
            <column name="reviewed_by" type="VARCHAR(100)"/>
            <column name="reviewed_at" type="TIMESTAMP"/>
            <column name="review_comments" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="025-02-duplicate-matches-indexes" author="adakalgroup">
        <createIndex indexName="idx_dup_match_status" tableName="duplicate_matches">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_dup_match_client_type" tableName="duplicate_matches">
            <column name="client_type"/>
        </createIndex>
        <createIndex indexName="idx_dup_match_score" tableName="duplicate_matches">
            <column name="similarity_score"/>
        </createIndex>
        <createIndex indexName="idx_dup_match_created" tableName="duplicate_matches">
            <column name="created_at"/>
        </createIndex>
        <createIndex indexName="idx_dup_match_clients" tableName="duplicate_matches" unique="true">
            <column name="client_id_1"/>
            <column name="client_id_2"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
