<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="011-1-create-reconciliation-tasks" author="bdqm">
        <createTable tableName="reconciliation_tasks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ticket_id" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="pending">
                <constraints nullable="false"/>
            </column>
            <column name="attempts" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="reconciled_at" type="DATETIME"/>
            <column name="last_attempt_at" type="DATETIME"/>
            <column name="error_message" type="TEXT"/>
        </createTable>

        <createIndex tableName="reconciliation_tasks" indexName="idx_recon_tasks_ticket_id">
            <column name="ticket_id"/>
        </createIndex>
        <createIndex tableName="reconciliation_tasks" indexName="idx_recon_tasks_client_id">
            <column name="client_id"/>
        </createIndex>
        <createIndex tableName="reconciliation_tasks" indexName="idx_recon_tasks_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="reconciliation_tasks" indexName="idx_recon_tasks_created_at">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="011-2-create-corrections" author="bdqm">
        <createTable tableName="corrections">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ticket_id" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="field_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="field_label" type="VARCHAR(100)"/>
            <column name="old_value" type="TEXT"/>
            <column name="new_value" type="TEXT"/>
            <column name="cbs_value" type="TEXT"/>
            <column name="is_matched" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="last_checked_at" type="DATETIME"/>
        </createTable>

        <createIndex tableName="corrections" indexName="idx_corrections_ticket_id">
            <column name="ticket_id"/>
        </createIndex>
        <addUniqueConstraint tableName="corrections"
            columnNames="ticket_id,field_name"
            constraintName="uk_corrections_ticket_field"/>
    </changeSet>

</databaseChangeLog>
