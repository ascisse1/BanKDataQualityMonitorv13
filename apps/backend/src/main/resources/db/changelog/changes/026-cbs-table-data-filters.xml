<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="026-01-add-data-filters-column" author="adakalgroup">
        <addColumn tableName="cbs_tables" schemaName="public">
            <column name="data_filters" type="JSONB">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <comment>Add configurable data filters (JSON array) to CBS tables for sync/validation filtering</comment>
    </changeSet>

</databaseChangeLog>
