<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://flowable.org/bpmn">

  <process id="ticket-correction-process" name="Ticket Correction Workflow" isExecutable="true">

    <startEvent id="StartEvent_1" name="Anomaly Detected">
      <outgoing>Flow_1</outgoing>
    </startEvent>

    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CreateTicket"/>

    <serviceTask id="Task_CreateTicket" name="Create Ticket" flowable:delegateExpression="${createTicketDelegate}">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_2" sourceRef="Task_CreateTicket" targetRef="Task_AssignTicket"/>

    <serviceTask id="Task_AssignTicket" name="Assign to Agency User" flowable:delegateExpression="${assignTicketDelegate}">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_3" sourceRef="Task_AssignTicket" targetRef="Task_AgencyCorrection"/>

    <userTask id="Task_AgencyCorrection" name="Agency User Corrects Data" flowable:assignee="${assignedUserId}">
      <incoming>Flow_3</incoming>
      <incoming>Flow_Rework</incoming>
      <outgoing>Flow_4</outgoing>
    </userTask>

    <sequenceFlow id="Flow_4" sourceRef="Task_AgencyCorrection" targetRef="Task_RequestValidation"/>

    <serviceTask id="Task_RequestValidation" name="Request Validation" flowable:delegateExpression="${requestValidationDelegate}">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_5" sourceRef="Task_RequestValidation" targetRef="Task_ValidateCorrection"/>

    <userTask id="Task_ValidateCorrection" name="Supervisor Validates (4-Eyes)" flowable:candidateGroups="supervisors">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
    </userTask>

    <sequenceFlow id="Flow_6" sourceRef="Task_ValidateCorrection" targetRef="Gateway_ValidationDecision"/>

    <exclusiveGateway id="Gateway_ValidationDecision" name="Validation OK?">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_Approved</outgoing>
      <outgoing>Flow_Rejected</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_Approved" name="Approved" sourceRef="Gateway_ValidationDecision" targetRef="Task_TriggerRPA">
      <conditionExpression xsi:type="tFormalExpression">${validationApproved == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_Rejected" name="Rejected" sourceRef="Gateway_ValidationDecision" targetRef="Task_NotifyRejection">
      <conditionExpression xsi:type="tFormalExpression">${validationApproved == false}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="Task_NotifyRejection" name="Notify Rejection" flowable:delegateExpression="${notifyRejectionDelegate}">
      <incoming>Flow_Rejected</incoming>
      <outgoing>Flow_Rework</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_Rework" sourceRef="Task_NotifyRejection" targetRef="Task_AgencyCorrection"/>

    <serviceTask id="Task_TriggerRPA" name="Trigger RPA (UiPath)" flowable:delegateExpression="${triggerRpaDelegate}">
      <incoming>Flow_Approved</incoming>
      <outgoing>Flow_7</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_7" sourceRef="Task_TriggerRPA" targetRef="Task_WaitRPACompletion"/>

    <receiveTask id="Task_WaitRPACompletion" name="Wait for RPA Completion">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </receiveTask>

    <sequenceFlow id="Flow_8" sourceRef="Task_WaitRPACompletion" targetRef="Gateway_RPASuccess"/>

    <exclusiveGateway id="Gateway_RPASuccess" name="RPA Success?">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_RPASuccess</outgoing>
      <outgoing>Flow_RPAFailed</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_RPASuccess" name="Success" sourceRef="Gateway_RPASuccess" targetRef="Task_CloseTicket">
      <conditionExpression xsi:type="tFormalExpression">${rpaSuccess == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_RPAFailed" name="Failed" sourceRef="Gateway_RPASuccess" targetRef="Task_HandleRPAFailure">
      <conditionExpression xsi:type="tFormalExpression">${rpaSuccess == false}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="Task_HandleRPAFailure" name="Handle RPA Failure" flowable:delegateExpression="${handleRpaFailureDelegate}">
      <incoming>Flow_RPAFailed</incoming>
      <outgoing>Flow_9</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_9" sourceRef="Task_HandleRPAFailure" targetRef="EndEvent_RPAFailed"/>

    <endEvent id="EndEvent_RPAFailed" name="RPA Failed - Manual Intervention Required">
      <incoming>Flow_9</incoming>
    </endEvent>

    <serviceTask id="Task_CloseTicket" name="Close Ticket" flowable:delegateExpression="${closeTicketDelegate}">
      <incoming>Flow_RPASuccess</incoming>
      <outgoing>Flow_10</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_10" sourceRef="Task_CloseTicket" targetRef="Task_UpdateKPIs"/>

    <serviceTask id="Task_UpdateKPIs" name="Update KPIs" flowable:delegateExpression="${updateKpisDelegate}">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_11" sourceRef="Task_UpdateKPIs" targetRef="EndEvent_Success"/>

    <endEvent id="EndEvent_Success" name="Ticket Closed Successfully">
      <incoming>Flow_11</incoming>
    </endEvent>

  </process>

</definitions>
